{
  "manifest_version": 3,
  "name": "ReadToMe",
  "description": "Read selected text aloud using Google Cloud Text-to-Speech Chirp voices.",
  "version": "1.0.0",
  "permissions": ["contextMenus", "storage", "offscreen"],
  "host_permissions": ["https://texttospeech.googleapis.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "minimum_chrome_version": "109"
}
